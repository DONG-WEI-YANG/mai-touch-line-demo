# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8081

# ============================================
# Database Configuration
# ============================================
# Database type: sqlite, mysql, postgres
DB_TYPE=sqlite

# SQLite Configuration (default for development)
SQLITE_FILENAME=./data/mai-touch.db

# MySQL Configuration (for production)
# DATABASE_URL=mysql://user:password@localhost:3306/mai_touch
# Or use individual settings:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=mai_touch

# PostgreSQL Configuration (alternative)
# DATABASE_URL=postgres://user:password@localhost:5432/mai_touch
# Or use individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=mai_touch

# ============================================
# OpenAI API
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Storage Service
# ============================================
BUILT_IN_FORGE_API_URL=https://your-storage-api.com
BUILT_IN_FORGE_API_KEY=your_storage_api_key_here

# ============================================
# Session & Security
# ============================================
SESSION_SECRET=your_random_session_secret_here_change_in_production
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds
COOKIE_DOMAIN=localhost
OWNER_OPEN_ID=your_owner_open_id_here

# ============================================
# OAuth Configuration
# ============================================
OAUTH_ENABLED=true

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth
APPLE_CLIENT_ID=your_apple_client_id
APPLE_CLIENT_SECRET=your_apple_client_secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Custom OAuth
CUSTOM_OAUTH_CLIENT_ID=your_custom_client_id
CUSTOM_OAUTH_CLIENT_SECRET=your_custom_client_secret
CUSTOM_OAUTH_AUTHORIZATION_URL=https://your-domain.com/oauth/authorize
CUSTOM_OAUTH_TOKEN_URL=https://your-domain.com/oauth/token
CUSTOM_OAUTH_USERINFO_URL=https://your-domain.com/oauth/userinfo
CUSTOM_OAUTH_SCOPE=openid profile email

# ============================================
# Email Service (Nodemailer)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM=noreply@your-domain.com
EMAIL_DRY_RUN=false

# ============================================
# SMS Service (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
SMS_DRY_RUN=false

# ============================================
# NLP Service
# ============================================
NLP_SERVICE_URL=http://localhost:8000

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
CORS_ORIGIN=http://localhost:8081

# ============================================
# Voice Transcription Service
# ============================================
VOICE_API_URL=https://api.openai.com/v1/audio/transcriptions
VOICE_API_KEY=your_openai_api_key_here

# ============================================
# Rate Limiting
# ============================================
TRUSTED_IPS=127.0.0.1,::1

# ============================================
# Cache Configuration
# ============================================
CACHE_TTL=300

# ============================================
# Notification Settings
# ============================================
PUSH_NOTIFICATIONS_ENABLED=true
EXPO_PROJECT_ID=your_expo_project_id

# ============================================
# Offline Mode
# ============================================
OFFLINE_SYNC_INTERVAL=30000
OFFLINE_MAX_RETRIES=3

# ============================================
# Development Flags
# ============================================
DEBUG=true
LOG_LEVEL=info

# ============================================
# Deploy Profile
# ============================================
# 'demo' = OpenAI-only, 'prod' = existing NLP service
DEPLOY_PROFILE=prod

# ============================================
# LINE Messaging API (demo profile)
# ============================================
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# Comma-separated LINE userIds allowed /role admin and /demo reset
DEMO_ADMIN_LINE_USERS=

# ============================================
# OpenAI (demo profile only)
# ============================================
OPENAI_MODEL=gpt-4o-mini
