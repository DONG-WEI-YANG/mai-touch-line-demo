{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx expo export -p web --output-dir dist",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm ci",
  "rewrites": [
    { "source": "/((?!_expo|assets|favicon|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
