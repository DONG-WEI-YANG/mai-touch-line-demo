{
  "name": "luxury-building-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "server": "ts-node src/server/index.ts",
    "dev:server": "nodemon src/server/index.ts",
    "db:migrate": "ts-node src/server/database/migrate.ts up",
    "db:rollback": "ts-node src/server/database/migrate.ts rollback",
    "db:reset": "ts-node src/server/database/migrate.ts reset",
    "db:init": "ts-node scripts/init-db.ts",
    "db:init:simple": "ts-node scripts/init-db-simple.ts",
    "setup": "node scripts/setup.bat",
    "test": "vitest run",
    "lint": "eslint src/ --max-warnings 50",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules dist .expo"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.9.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.0",
    "@trpc/react-query": "^10.45.0",
    "@trpc/server": "^10.45.0",
    "better-sqlite3": "^9.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.1",
    "events": "^3.3.0",
    "expo": "^54.0.33",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-notifications": "^0.32.16",
    "expo-router": "3.5.24",
    "expo-status-bar": "~3.0.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "lucide-react-native": "^0.300.0",
    "mysql2": "^3.6.5",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.1",
    "openai": "^4.104.0",
    "postgres": "^3.4.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.11",
    "react-native-web": "^0.19.13",
    "superjson": "^2.2.1",
    "twilio": "^4.19.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "~18.2.45",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "nock": "^14.0.14",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "private": true
}
