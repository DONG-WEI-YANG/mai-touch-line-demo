#
# Local web/backend pairing for stable development on Windows/macOS/Linux.
# Copy this file to `.env.local` and adjust values if needed.
#

# Fixed local ports
LOCAL_API_PORT=3011
LOCAL_WEB_PORT=8081

# Backend
PORT=3011
BASE_URL=http://localhost:3011
FRONTEND_URL=http://localhost:8081

# Frontend
EXPO_PUBLIC_API_URL=http://localhost:3011

# Local CORS whitelist for Expo Web
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:8082,http://127.0.0.1:8082,http://localhost:8083,http://127.0.0.1:8083,http://localhost:19006,http://127.0.0.1:19006

# Demo web login tokens
WEB_ADMIN_TOKEN=tok-admin
WEB_LOGISTICS_TOKEN=tok-logistics
WEB_RESIDENT_TOKEN=tok-resident

# Expo web quick-login tokens (must match WEB_* above)
EXPO_PUBLIC_DEMO_ADMIN_TOKEN=tok-admin
EXPO_PUBLIC_DEMO_LOGISTICS_TOKEN=tok-logistics
EXPO_PUBLIC_DEMO_RESIDENT_TOKEN=tok-resident
